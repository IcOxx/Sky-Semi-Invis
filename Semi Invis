            isInvisible = true
            statusLabel.Text = "Status : ✓ Invisible"
            statusLabel.TextColor3 = Color3.fromRGB(80, 255, 150)
            toggleBtn.Text = "⬡  SEMI INVIS ✓"
        end
    else
        disableInvisibility()
        isInvisible = false
        statusLabel.Text = "Status : Visible"
        statusLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
        toggleBtn.Text = "⬡  SEMI INVIS"
        for _, conn in ipairs(connections.SemiInvisible) do if conn then conn:Disconnect() end end
        connections.SemiInvisible = {}
    end
end)
